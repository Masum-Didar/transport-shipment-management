<% content_for :page_title, "Driver Assignments" %>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Driver</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Truck</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Assigned By</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">From</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">To</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @assignments.each do |a| %>
        <tr>
          <td class="px-4 py-3"><%= link_to a.driver.name, a.driver, class: "text-blue-600" %></td>
          <td class="px-4 py-3"><%= link_to a.truck.truck_number, a.truck, class: "text-blue-600" %></td>
          <td class="px-4 py-3 text-sm"><%= a.assigned_by.name %></td>
          <td class="px-4 py-3 text-sm"><%= l(a.assigned_at, format: :short) %></td>
          <td class="px-4 py-3 text-sm"><%= a.released_at ? l(a.released_at, format: :short) : status_badge("active") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
