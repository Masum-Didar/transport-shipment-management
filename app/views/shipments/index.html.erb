<% content_for :page_title, "Shipments" %>

<div class="flex justify-between items-center mb-4">
  <%= form_tag shipments_path, method: :get, class: "flex gap-2 items-center flex-wrap" do %>
    <%= text_field_tag :q, params[:q], placeholder: "Search #...", class: "rounded border-gray-300 text-sm px-3 py-1.5 w-32" %>
    <%= select_tag :type, options_for_select([["All Types", ""], ["Import", "import"], ["Export", "export"]], params[:type]), class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= select_tag :status, options_for_select([["All Status", ""], "Pending", "Loading", "Loaded", "On The Way", "Reached", "Unloading", "Completed"], params[:status]), class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= date_field_tag :from_date, params[:from_date], class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= date_field_tag :to_date, params[:to_date], class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= submit_tag "Filter", class: "bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm hover:bg-gray-200" %>
  <% end %>
  <%= link_to "+ New Shipment", new_shipment_path, class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" if policy(Shipment).new? %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Source → Destination</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Truck</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @shipments.each do |s| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3"><%= link_to s.shipment_number, s, class: "text-blue-600 hover:text-blue-800 font-medium" %></td>
          <td class="px-4 py-3"><%= status_badge(s.shipment_type) %></td>
          <td class="px-4 py-3 text-sm"><%= s.source_location&.name %> → <%= s.destination_location&.name %></td>
          <td class="px-4 py-3 text-sm"><%= s.truck&.truck_number || "—" %></td>
          <td class="px-4 py-3"><%= status_badge(s.status) %></td>
          <td class="px-4 py-3 text-sm"><%= l(s.shipment_date, format: :short) %></td>
          <td class="px-4 py-3">
            <%= link_to "👁", s, class: "text-gray-600 hover:text-gray-800 mr-2", title: "View" %>
            <% if policy(s).update_status? && s.status != "completed" %>
              <%= link_to "✏️", edit_shipment_path(s), class: "text-gray-600 hover:text-gray-800 mr-2", title: "Edit" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @shipments.empty? %>
    <p class="text-center text-gray-500 py-8">No shipments found.</p>
  <% end %>
</div>
