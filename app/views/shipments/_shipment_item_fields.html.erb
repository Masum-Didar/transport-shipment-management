<tr class="nested-fields">
  <td class="px-4 py-2">
    <%= f.collection_select :product_id, Product.kept, :id, :name, { prompt: "Select" }, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none w-full" %>
    <%= f.hidden_field :_destroy %>
  </td>
  <td class="px-4 py-2"><%= f.number_field :quantity, step: 0.01, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none w-full" %></td>
  <td class="px-4 py-2"><%= f.number_field :weight, step: 0.01, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none w-full" %></td>
  <td class="px-4 py-2"><%= f.text_field :unit, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none w-full" %></td>
  <td class="px-4 py-2">
    <button type="button" data-action="nested-form#remove" class="text-red-600 text-sm hover:text-red-800 font-medium flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
      Remove
    </button>
  </td>
</tr>
