<% content_for :page_title, "Routes" %>

<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-semibold text-gray-900">Routes</h1>
    <%= link_to new_route_path, class: "flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors" do %>
      <%= plus_icon %>
      Add Route
    <% end if policy(Route).new? %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">From</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">To</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Distance</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Est. Time</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if @routes.empty? %>
            <tr>
              <td colspan="5">
                <%= render EmptyStateComponent.new(icon: "🗺️", title: "No routes found", description: "Add your first route to get started", action: link_to("+ Add Route", new_route_path, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700")) %>
              </td>
            </tr>
          <% else %>
            <% @routes.each do |route| %>
              <tr class="hover:bg-blue-50/40 transition-colors duration-100">
                <td class="px-4 py-3 text-sm font-medium text-gray-800"><%= route.from_location.name %></td>
                <td class="px-4 py-3 text-sm font-medium text-gray-800"><%= route.to_location.name %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= route.distance_km %> km</td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= route.estimated_hours %> hrs</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1">
                    <%= link_to edit_route_path(route), class: "p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-md transition-colors", title: "Edit" do %>
                      <%= edit_icon %>
                    <% end if policy(route).edit? %>
                    <%= link_to route, method: :delete, data: { confirm: "Are you sure?" }, class: "p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors", title: "Delete" do %>
                      <%= trash_icon %>
                    <% end if policy(route).destroy? %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
