<%= render "shared/form_errors", object: route %>
<%= form_with model: route, class: "space-y-4" do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :from_location_id, "From", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :from_location_id, Location.kept, :id, :name, { prompt: "Select" }, required: true, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :to_location_id, "To", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :to_location_id, Location.kept, :id, :name, { prompt: "Select" }, required: true, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :distance_km, "Distance (km)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :distance_km, step: 0.01, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :estimated_hours, "Est. Time (hrs)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :estimated_hours, step: 0.5, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
  </div>
  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :notes, rows: 2, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>
  <div class="flex gap-2">
    <%= f.submit class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    <%= link_to "Cancel", routes_path, class: "bg-gray-100 text-gray-700 px-4 py-2 rounded hover:bg-gray-200" %>
  </div>
<% end %>
