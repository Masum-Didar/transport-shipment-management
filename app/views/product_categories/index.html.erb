<% content_for :page_title, "Product Categories" %>

<div class="flex justify-between items-center mb-4">
  <span class="text-sm text-gray-500"><%= pluralize(@categories.count, "category") %></span>
  <%= link_to "+ Add Category", new_product_category_path, class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" if policy(ProductCategory).new? %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Products</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @categories.each do |cat| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium"><%= cat.name %></td>
          <td class="px-4 py-3 text-sm"><%= cat.products.kept.count %></td>
          <td class="px-4 py-3">
            <%= link_to "✏️", edit_product_category_path(cat), class: "text-gray-600 hover:text-gray-800 mr-2", title: "Edit" if policy(cat).edit? %>
            <%= link_to "🗑", cat, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800", title: "Delete" if policy(cat).destroy? %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @categories.empty? %>
    <p class="text-center text-gray-500 py-8">No categories found.</p>
  <% end %>
</div>
