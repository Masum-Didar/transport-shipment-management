<% content_for :page_title, "Product Categories" %>

<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-semibold text-gray-900">Product Categories</h1>
    <%= link_to new_product_category_path, class: "flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors" do %>
      <%= plus_icon %>
      Add Category
    <% end if policy(ProductCategory).new? %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Products</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if @categories.empty? %>
            <tr>
              <td colspan="3">
                <%= render EmptyStateComponent.new(icon: "🏷️", title: "No categories found", description: "Add your first category to organize products", action: link_to("+ Add Category", new_product_category_path, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700")) %>
              </td>
            </tr>
          <% else %>
            <% @categories.each do |cat| %>
              <tr class="hover:bg-blue-50/40 transition-colors duration-100">
                <td class="px-4 py-3 text-sm font-medium text-gray-800"><%= cat.name %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= cat.products.kept.count %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1">
                    <%= link_to edit_product_category_path(cat), class: "p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-md transition-colors", title: "Edit" do %>
                      <%= edit_icon %>
                    <% end if policy(cat).edit? %>
                    <%= link_to cat, method: :delete, data: { confirm: "Are you sure?" }, class: "p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors", title: "Delete" do %>
                      <%= trash_icon %>
                    <% end if policy(cat).destroy? %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
