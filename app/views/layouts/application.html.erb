<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "TSM System" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="description" content="Transport Management System">
    <meta name="theme-color" content="#2563EB">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.svg">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= tag.meta name: "turbo-refresh-method", content: "morph" %>
  </head>

  <body class="bg-gray-50 font-sans min-h-screen" data-controller="sidebar" data-sidebar-collapsed-value="false">
    <% if user_signed_in? %>
      <%= render "shared/sidebar" %>

      <div data-sidebar-target="overlay" class="fixed inset-0 bg-black/50 z-40 lg:hidden hidden" data-action="click->sidebar#closeMobile"></div>
      <aside data-sidebar-target="mobileSidebar" class="fixed inset-y-0 left-0 w-64 bg-slate-800 z-50 lg:hidden hidden flex-col">
        <div class="flex items-center justify-between px-5 py-5 border-b border-slate-700">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center">
              <span class="text-white text-base">📦</span>
            </div>
            <div>
              <div class="text-white font-semibold text-sm">TSM System</div>
              <div class="text-slate-400 text-xs">Transport Management</div>
            </div>
          </div>
          <button data-action="click->sidebar#closeMobile" class="text-slate-400 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
          <% nav_items_for_mobile.each do |item| %>
            <%= link_to item[:path], class: "w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all #{current_page?(item[:path]) ? 'bg-blue-600 text-white' : 'text-slate-300 hover:bg-slate-700'}" do %>
              <%= send(item[:icon]) %>
              <span class="sidebar-label"><%= item[:label] %></span>
            <% end %>
          <% end %>
        </nav>
      </aside>

      <div data-sidebar-target="content" class="lg:ml-64 min-h-screen flex flex-col">
        <%= render "shared/navbar" %>

        <main class="flex-1 pb-20 lg:pb-6">
          <div class="p-4 lg:p-6">
            <%= yield %>
          </div>
        </main>
      </div>

      <%= render "shared/bottom_nav" %>
    <% else %>
      <main class="min-h-screen flex items-center justify-center">
        <%= yield %>
      </main>
    <% end %>
    <%= render "shared/flash" %>
  </body>
</html>
