<aside data-sidebar-target="desktopSidebar" class="hidden lg:flex flex-col w-64 bg-slate-800 border-r border-slate-700 fixed inset-y-0 left-0 z-30 transition-all duration-200">
  <div class="flex items-center gap-3 px-5 h-16 border-b border-slate-700 shrink-0">
    <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center flex-shrink-0">
      <span class="text-white text-base font-bold">📦</span>
    </div>
    <div class="sidebar-label">
      <div class="text-white font-semibold text-sm leading-tight">TSM System</div>
      <div class="text-slate-400 text-xs">Transport Management</div>
    </div>
  </div>

  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    <div class="tooltip-wrapper">
      <%= nav_link "Dashboard", root_path, "dashboard" %>
    </div>
    <div class="tooltip-wrapper">
      <%= nav_link "Shipments", shipments_path, "clipboard_list" %>
    </div>
    <div class="tooltip-wrapper">
      <%= nav_link "Trucks", trucks_path, "truck" %>
    </div>
    <div class="tooltip-wrapper">
      <%= nav_link "Drivers", drivers_path, "users" %>
    </div>
    <div class="tooltip-wrapper">
      <%= nav_link "Products", products_path, "package" %>
    </div>
    <div class="tooltip-wrapper">
      <%= nav_link "Locations", locations_path, "map_pin" %>
    </div>
    <div class="tooltip-wrapper">
      <%= nav_link "Routes", routes_path, "map" %>
    </div>

    <div class="pt-3 pb-1 px-1">
      <div class="h-px bg-slate-700"></div>
    </div>

    <div class="tooltip-wrapper">
      <%= nav_link "Reports", reports_daily_path, "bar_chart" %>
    </div>
    <div class="tooltip-wrapper">
      <%= nav_link "Notifications", notifications_path, "bell" %>
    </div>

    <div class="pt-3 pb-1 px-1 sidebar-label">
      <div class="h-px bg-slate-700"></div>
      <p class="text-xs text-slate-500 font-medium px-2 pt-2 pb-1 uppercase tracking-wider">Admin</p>
    </div>

    <% if current_user.admin? %>
      <div class="tooltip-wrapper">
        <%= nav_link "Audit Log", audit_logs_path, "file_text" %>
      </div>
    <% end %>
    <div class="tooltip-wrapper">
      <%= nav_link "Settings", settings_path, "settings" if current_user.admin? %>
    </div>
  </nav>

  <div class="px-3 py-4 border-t border-slate-700">
    <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-slate-700/50">
      <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-semibold shrink-0">
        <%= current_user.name.split.map { |n| n[0] }.join[0..1].upcase %>
      </div>
      <div class="sidebar-label flex-1 min-w-0">
        <div class="text-white text-sm font-medium truncate"><%= current_user.name %></div>
        <div class="text-slate-400 text-xs"><%= current_user.role.name.titleize %></div>
      </div>
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "text-slate-400 hover:text-white transition-colors shrink-0" do %>
        <%= log_out_icon %>
      <% end %>
    </div>
  </div>
</aside>
