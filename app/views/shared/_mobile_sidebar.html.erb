<% if local_assigns[:open] %>
  <div class="fixed inset-0 bg-black/50 z-40 lg:hidden" data-action="click->sidebar#close"></div>
  <aside class="fixed inset-y-0 left-0 w-64 bg-slate-800 z-50 lg:hidden flex flex-col">
    <div class="flex items-center justify-between px-5 py-5 border-b border-slate-700">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center">
          <span class="text-white text-base">📦</span>
        </div>
        <div>
          <div class="text-white font-semibold text-sm">TSM System</div>
          <div class="text-slate-400 text-xs">Transport Management</div>
        </div>
      </div>
      <button data-action="click->sidebar#close" class="text-slate-400 hover:text-white">
        <%= x_icon %>
      </button>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
      <% nav_items_for_mobile.each do |item| %>
        <%= link_to item[:path], class: "w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all #{current_page?(item[:path]) ? 'bg-blue-600 text-white' : 'text-slate-300 hover:bg-slate-700'}" do %>
          <%= send(item[:icon]) %>
          <span><%= item[:label] %></span>
        <% end %>
      <% end %>
    </nav>
  </aside>
<% end %>
