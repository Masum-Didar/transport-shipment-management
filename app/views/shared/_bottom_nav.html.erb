<nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-20 h-16">
  <div class="flex h-full">
    <% bottom_nav_items.each do |item| %>
      <%= link_to item[:path], class: "flex-1 flex flex-col items-center justify-center gap-1 relative transition-colors #{current_page?(item[:path]) ? 'text-blue-600' : 'text-gray-500'}" do %>
        <%= send(item[:icon]) %>
        <span class="text-xs font-medium"><%= item[:label] %></span>
        <% if item[:badge] && (count = current_user.notifications.unread.count) > 0 %>
          <span class="absolute top-1 right-1/4 w-4 h-4 bg-red-500 text-white text-xs rounded-full flex items-center justify-center"><%= count %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
</nav>
