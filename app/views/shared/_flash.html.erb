<div class="fixed bottom-4 right-4 z-50 space-y-2">
  <% if flash[:notice] %>
    <div class="flex items-center gap-3 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-xl shadow-lg text-sm animate-slide-in-right" data-controller="toast">
      <%= check_icon %>
      <span><%= flash[:notice] %></span>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div class="flex items-center gap-3 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-xl shadow-lg text-sm animate-slide-in-right" data-controller="toast">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      <span><%= flash[:alert] %></span>
    </div>
  <% end %>
</div>
