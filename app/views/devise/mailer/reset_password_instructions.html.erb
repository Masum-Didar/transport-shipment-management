<!doctype html>
<html>
<head><meta charset="utf-8"></head>
<body style="font-family:'Inter',system-ui,sans-serif;background:#F9FAFB;padding:2rem 1rem">
  <table align="center" style="max-width:480px;width:100%;background:#fff;border-radius:12px;border:1px solid #E5E7EB;padding:2rem">
    <tr><td style="text-align:center;padding-bottom:1.5rem">
      <div style="width:48px;height:48px;background:#2563EB;border-radius:14px;display:inline-flex;align-items:center;justify-content:center;font-size:1.25rem;box-shadow:0 4px 12px rgba(37,99,235,.2)">🔑</div>
      <h1 style="font-size:1.125rem;font-weight:600;color:#111827;margin:.75rem 0 0">Reset your password</h1>
    </td></tr>
    <tr><td style="font-size:.875rem;color:#6B7280;line-height:1.6;padding-bottom:1.5rem">
      <p style="margin:0 0 1rem">Someone has requested a password reset for your TSM System account. Click the button below to set a new password.</p>
    </td></tr>
    <tr><td style="text-align:center;padding-bottom:1.5rem">
      <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>" style="display:inline-block;background:#2563EB;color:#fff;font-size:.875rem;font-weight:500;padding:.75rem 1.5rem;border-radius:8px;text-decoration:none">Reset Password</a>
    </td></tr>
    <tr><td style="font-size:.75rem;color:#9CA3AF;text-align:center">
      <p style="margin:0 0 .25rem">If you didn't request this, please ignore this email.</p>
      <p style="margin:0">Your password won't change until you click the link and create a new one.</p>
    </td></tr>
  </table>
</body>
</html>
