<div class="w-full max-w-sm mx-auto">
  <div class="text-center mb-8">
    <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
      <span class="text-white text-2xl">🔑</span>
    </div>
    <h1 class="text-xl font-bold text-gray-900"><%= t("auth.forgot_password") %></h1>
    <p class="text-sm text-gray-500 mt-1">Enter your email and we'll send you reset instructions.</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition", placeholder: "you@example.com" %>
      </div>

      <%= f.submit "Send Reset Instructions", class: "w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition cursor-pointer" %>
    <% end %>

    <div class="mt-4 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
