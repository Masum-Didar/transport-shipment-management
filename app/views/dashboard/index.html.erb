<% content_for :page_title, "Dashboard" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-semibold text-gray-900">Dashboard</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= l(Date.current, format: :long) %></p>
    </div>
    <%= link_to new_shipment_path, class: "hidden sm:flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors" do %>
      <%= plus_icon %>
      New Shipment
    <% end if policy(Shipment).new? %>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="animate-slide-up stagger-1"><%= render StatCardComponent.new(label: "Active Shipments", value: @active_shipments, icon: "📤", color: "text-blue-600", trend: "Today so far", trend_up: true) %></div>
    <div class="animate-slide-up stagger-2"><%= render StatCardComponent.new(label: "Completed Today", value: @completed_today, icon: "✅", color: "text-green-600", trend: "#{@completed_percentage}% rate", trend_up: @completed_percentage > 50) %></div>
    <div class="animate-slide-up stagger-3"><%= render StatCardComponent.new(label: "Total Trucks", value: @total_trucks, icon: "🚛", color: "text-purple-600", trend: "#{@active_trucks} on route") %></div>
    <div class="animate-slide-up stagger-4"><%= render StatCardComponent.new(label: "Drivers on Duty", value: @drivers_on_duty, icon: "👨‍✈️", color: "text-teal-600", trend: "Today active", trend_up: true) %></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2 bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-900">Weekly Shipments</h2>
        <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-md">This Week</span>
      </div>
      <div class="space-y-3">
        <% max_val = [@weekly_data.map { |d| d[:export] + d[:import] }.max, 1].max %>
        <% @weekly_data.each do |data| %>
          <div class="flex items-center gap-3 text-xs">
            <span class="w-8 text-gray-500 font-medium"><%= data[:day] %></span>
            <div class="flex-1 space-y-1">
              <div class="flex items-center gap-1">
                <div class="h-3 bg-blue-600 rounded-sm" style="width: <%= (data[:export].to_f / max_val * 100).clamp(0, 100) %>%"></div>
                <span class="text-gray-400"><%= data[:export] %></span>
              </div>
              <div class="flex items-center gap-1">
                <div class="h-3 bg-teal-500 rounded-sm" style="width: <%= (data[:import].to_f / max_val * 100).clamp(0, 100) %>%"></div>
                <span class="text-gray-400"><%= data[:import] %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="flex items-center gap-4 mt-3 pt-3 border-t border-gray-100">
        <div class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-3 h-3 rounded-sm bg-blue-600 inline-block"></span> Export</div>
        <div class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-3 h-3 rounded-sm bg-teal-500 inline-block"></span> Import</div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-4">Top Routes</h2>
      <div class="space-y-3">
        <% if @top_routes.any? %>
          <% max_route_count = @top_routes.first[:count] %>
          <% @top_routes.each_with_index do |r, i| %>
            <% colors = ["bg-blue-500", "bg-teal-500", "bg-purple-400", "bg-green-400", "bg-orange-400"] %>
            <div>
              <div class="flex items-center justify-between text-xs mb-1">
                <span class="font-mono text-gray-700"><%= r[:name] %></span>
                <span class="text-gray-500 font-medium"><%= r[:count] %></span>
              </div>
              <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full <%= colors[i % colors.length] %>" style="width: <%= (r[:count].to_f / max_route_count * 100).clamp(0, 100) %>%"></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-400 text-center py-6">No route data yet</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-1 bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-4">Shipment Status</h2>
      <div class="space-y-2.5">
        <% %w[pending loading loaded on_the_way reached unloading completed].each do |status| %>
          <div class="flex items-center justify-between">
            <%= status_badge(status) %>
            <span class="font-mono text-sm font-semibold text-gray-700"><%= @status_counts[status] || 0 %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-2 bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-900">Recent Shipments</h2>
        <%= link_to shipments_path, class: "text-xs text-blue-600 hover:text-blue-800 font-medium flex items-center gap-1" do %>
          View All
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <% end %>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-100">
              <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">ID</th>
              <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Route</th>
              <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Driver</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% @recent_shipments.each do |s| %>
              <tr class="hover:bg-blue-50/40 transition-colors duration-100">
                <td class="px-4 py-3">
                  <%= link_to s.shipment_number, s, class: "font-mono text-xs text-blue-700 font-semibold" %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-700">
                  <%= s.source_location&.name %> → <%= s.destination_location&.name %>
                </td>
                <td class="px-4 py-3"><%= status_badge(s.status) %></td>
                <td class="px-4 py-3 text-sm text-gray-600"><%= s.truck&.current_driver&.name || "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if @recent_shipments.empty? %>
          <%= render EmptyStateComponent.new(icon: "📋", title: "No shipments yet", description: "Create your first shipment to get started") %>
        <% end %>
      </div>
    </div>
  </div>
</div>
