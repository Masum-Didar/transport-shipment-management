<% content_for :page_title, "Dashboard" %>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow p-5 border-l-4 border-blue-500">
    <div class="text-3xl font-bold text-blue-600"><%= @today_export %></div>
    <div class="text-gray-600">📤 Today's Export</div>
  </div>
  <div class="bg-white rounded-lg shadow p-5 border-l-4 border-purple-500">
    <div class="text-3xl font-bold text-purple-600"><%= @today_import %></div>
    <div class="text-gray-600">📥 Today's Import</div>
  </div>
  <div class="bg-white rounded-lg shadow p-5 border-l-4 border-orange-500">
    <div class="text-3xl font-bold text-orange-600"><%= @active_trucks %></div>
    <div class="text-gray-600">🚛 Active Trucks</div>
  </div>
  <div class="bg-white rounded-lg shadow p-5 border-l-4 border-green-500">
    <div class="text-3xl font-bold text-green-600"><%= @completed_today %></div>
    <div class="text-gray-600">✅ Completed Today</div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow p-5 border-l-4 border-blue-500">
    <div class="text-2xl font-bold"><%= @loading_trucks %></div>
    <div class="text-gray-600">🔄 Loading</div>
  </div>
  <div class="bg-white rounded-lg shadow p-5 border-l-4 border-teal-500">
    <div class="text-2xl font-bold"><%= @reached_shipments %></div>
    <div class="text-gray-600">📍 Reached</div>
  </div>
  <div class="bg-white rounded-lg shadow p-5 border-l-4 border-yellow-500">
    <div class="text-2xl font-bold"><%= @pending_shipments %></div>
    <div class="text-gray-600">⏳ Pending</div>
  </div>
</div>

<div class="bg-white rounded-lg shadow p-5 mb-6">
  <h3 class="font-semibold text-gray-700 mb-3">📊 Completion Rate</h3>
  <div class="w-full bg-gray-200 rounded-full h-4">
    <div class="bg-green-500 h-4 rounded-full" style="width: <%= @completed_percentage %>%"></div>
  </div>
  <p class="text-sm text-gray-500 mt-1"><%= @completed_percentage %>% completed today</p>
</div>

<div class="bg-white rounded-lg shadow p-5">
  <div class="flex justify-between items-center mb-4">
    <h3 class="font-semibold text-gray-700">📦 Recent Shipments</h3>
    <%= link_to "View All", shipments_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">#</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Truck</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @recent_shipments.each do |s| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2"><%= link_to s.shipment_number, s, class: "text-blue-600 hover:text-blue-800" %></td>
            <td class="px-4 py-2"><%= status_badge(s.shipment_type) %></td>
            <td class="px-4 py-2"><%= s.truck&.truck_number || "—" %></td>
            <td class="px-4 py-2"><%= status_badge(s.status) %></td>
            <td class="px-4 py-2 text-sm"><%= l(s.shipment_date, format: :short) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
