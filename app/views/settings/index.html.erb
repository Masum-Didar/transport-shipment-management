<% content_for :page_title, "Settings" %>

<% @groups.each do |group| %>
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h3 class="font-semibold text-gray-700 mb-4 capitalize"><%= group %> Settings</h3>
    <dl class="space-y-4">
      <% @settings.where(group: group).each do |setting| %>
        <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
          <dt class="text-sm font-medium text-gray-600"><%= setting.key.titleize %></dt>
          <dd class="text-sm">
            <%= form_with model: setting, local: true, class: "flex items-center gap-2" do |f| %>
              <% if setting.setting_type == "boolean" %>
                <%= f.select "setting[value]", [["Yes", "true"], ["No", "false"]], { selected: setting.value }, class: "rounded border-gray-300 text-sm" %>
              <% else %>
                <%= f.text_field "setting[value]", value: setting.value, class: "rounded border-gray-300 text-sm px-3 py-1" %>
              <% end %>
              <%= f.submit "Save", class: "bg-blue-600 text-white px-3 py-1 rounded text-xs hover:bg-blue-700" if policy(setting).update? %>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>
<% end %>
