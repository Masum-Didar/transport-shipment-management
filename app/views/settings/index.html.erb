<% content_for :page_title, "Settings" %>

<div data-controller="tabs" data-tabs-active-class="border-b-2 border-blue-600 text-blue-600" class="mb-6">
  <nav class="flex gap-6 border-b border-gray-200" role="tablist">
    <% @groups.each_with_index do |group, index| %>
      <button data-action="click->tabs#switch" data-tabs-target="tab" data-tab="<%= group %>"
              class="pb-3 text-sm font-medium text-gray-500 hover:text-gray-700 transition <%= 'border-b-2 border-blue-600 text-blue-600' if index == 0 %>">
        <span class="capitalize"><%= group %></span>
      </button>
    <% end %>
  </nav>

  <% @groups.each_with_index do |group, index| %>
    <div data-tabs-target="panel" data-panel="<%= group %>" class="<%= 'hidden' unless index == 0 %>">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mt-5">
        <div class="divide-y divide-gray-100">
          <% @settings.where(group: group).each do |setting| %>
            <div class="px-5 py-4 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-700 capitalize"><%= setting.key.titleize %></p>
                <% if setting.description.present? %>
                  <p class="text-xs text-gray-400 mt-0.5"><%= setting.description %></p>
                <% end %>
              </div>
              <div class="shrink-0 ml-4">
                <%= form_with model: setting, local: true, class: "flex items-center gap-2" do |f| %>
                  <% if setting.setting_type == "boolean" %>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <%= f.check_box "setting[value]", { checked: setting.value == "true", class: "sr-only peer" }, "true", "false" %>
                      <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                    </label>
                  <% else %>
                    <%= f.text_field "setting[value]", value: setting.value, class: "rounded-lg border border-gray-300 px-3 py-1.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition w-40" %>
                  <% end %>
                  <%= f.submit "Save", class: "bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium px-3 py-1.5 rounded-lg transition cursor-pointer" if policy(setting).update? %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
