<% content_for :page_title, "Driver Wise Report" %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-6">
  <%= form_tag reports_driver_wise_path, method: :get, class: "flex flex-wrap gap-3 items-center" do %>
    <div class="relative">
      <%= select_tag :driver_id, options_from_collection_for_select(Driver.kept, :id, :name, params[:driver_id]), { prompt: "Select Driver", class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition w-44" } %>
    </div>
    <div class="relative">
      <%= date_field_tag :from_date, params[:from_date], class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition" %>
    </div>
    <div class="relative">
      <%= date_field_tag :to_date, params[:to_date], class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition" %>
    </div>
    <%= submit_tag "Generate", class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition cursor-pointer" %>
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100">
    <h3 class="text-sm font-semibold text-gray-700">
      <%= params[:driver_id].present? ? Driver.find(params[:driver_id]).name : "All Drivers" %>
    </h3>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Driver</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Truck</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Released</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @assignments.each do |a| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-5 py-3 text-sm text-gray-700"><%= a.driver.name %></td>
            <td class="px-5 py-3 text-sm text-gray-600"><%= a.truck.truck_number %></td>
            <td class="px-5 py-3 text-sm text-gray-600"><%= l(a.assigned_at, format: :short) %></td>
            <td class="px-5 py-3 text-sm">
              <% if a.released_at %>
                <span class="text-gray-600"><%= l(a.released_at, format: :short) %></span>
              <% else %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                  Current
                </span>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @assignments.empty? %>
          <tr>
            <td colspan="4" class="px-5 py-12">
              <%= render EmptyStateComponent.new(icon: "👤", title: "No assignments", description: "No driver assignments match the selected filters.") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
