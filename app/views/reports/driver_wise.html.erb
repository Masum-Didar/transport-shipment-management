<% content_for :page_title, "Driver Wise Report" %>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <%= form_tag reports_driver_wise_path, method: :get, class: "flex gap-2 items-center" do %>
    <%= select_tag :driver_id, options_from_collection_for_select(Driver.kept, :id, :name, params[:driver_id]), { prompt: "Select Driver", class: "rounded border-gray-300 text-sm" } %>
    <%= date_field_tag :from_date, params[:from_date], class: "rounded border-gray-300 text-sm" %>
    <%= date_field_tag :to_date, params[:to_date], class: "rounded border-gray-300 text-sm" %>
    <%= submit_tag "Generate", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Driver</th><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Truck</th><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Assigned</th><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Released</th></tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @assignments.each do |a| %>
        <tr>
          <td class="px-4 py-2"><%= a.driver.name %></td>
          <td class="px-4 py-2"><%= a.truck.truck_number %></td>
          <td class="px-4 py-2 text-sm"><%= l(a.assigned_at, format: :short) %></td>
          <td class="px-4 py-2 text-sm"><%= a.released_at ? l(a.released_at, format: :short) : "Current" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
