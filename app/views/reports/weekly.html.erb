<% content_for :page_title, "Weekly Report" %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-6">
  <%= form_tag reports_weekly_path, method: :get, class: "flex flex-wrap gap-3 items-center" do %>
    <div class="relative">
      <%= date_field_tag :date, @week_start, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition" %>
    </div>
    <%= submit_tag "Generate", class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition cursor-pointer" %>
    <%= link_to reports_weekly_path(format: :csv, date: @week_start), class: "text-sm text-gray-500 hover:text-blue-600 flex items-center gap-1.5 ml-2" do %>
      <%= download_icon %> CSV
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
    <h3 class="text-sm font-semibold text-gray-700">
      <%= @week_start.strftime("%d %b") %> — <%= @week_end.strftime("%d %b %Y") %>
    </h3>
    <span class="text-xs text-gray-400"><%= pluralize @shipments.count, "shipment" %></span>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Count</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @grouped.each do |(date, type), count| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-5 py-3 text-sm text-gray-700"><%= date %></td>
            <td class="px-5 py-3"><%= status_badge(type) %></td>
            <td class="px-5 py-3 text-sm font-medium text-gray-900"><%= count %></td>
          </tr>
        <% end %>
        <% if @grouped.empty? %>
          <tr>
            <td colspan="3" class="px-5 py-12">
              <%= render EmptyStateComponent.new(icon: "📊", title: "No data", description: "No shipments for the selected week.") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
