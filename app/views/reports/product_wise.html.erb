<% content_for :page_title, "Product Wise Report" %>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <%= form_tag reports_product_wise_path, method: :get, class: "flex gap-2 items-center" do %>
    <%= select_tag :product_id, options_from_collection_for_select(Product.kept, :id, :name, params[:product_id]), { prompt: "Select Product", class: "rounded border-gray-300 text-sm" } %>
    <%= date_field_tag :from_date, params[:from_date], class: "rounded border-gray-300 text-sm" %>
    <%= date_field_tag :to_date, params[:to_date], class: "rounded border-gray-300 text-sm" %>
    <%= submit_tag "Generate", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Product</th><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Total Quantity</th></tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @grouped.each do |product_id, qty| %>
        <tr><td class="px-4 py-2"><%= Product.find(product_id).name rescue "Unknown" %></td><td class="px-4 py-2"><%= number_with_delimiter(qty) %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
