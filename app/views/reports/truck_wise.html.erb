<% content_for :page_title, "Truck Wise Report" %>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <%= form_tag reports_truck_wise_path, method: :get, class: "flex gap-2 items-center" do %>
    <%= select_tag :truck_id, options_from_collection_for_select(Truck.kept, :id, :truck_number, params[:truck_id]), { prompt: "Select Truck", class: "rounded border-gray-300 text-sm" } %>
    <%= date_field_tag :from_date, params[:from_date], class: "rounded border-gray-300 text-sm" %>
    <%= date_field_tag :to_date, params[:to_date], class: "rounded border-gray-300 text-sm" %>
    <%= submit_tag "Generate", class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow p-6">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Truck</th><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th><th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Count</th></tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @grouped.each do |(truck_id, status), count| %>
        <tr><td class="px-4 py-2"><%= Truck.find(truck_id).truck_number rescue "Unknown" %></td><td class="px-4 py-2"><%= status_badge(status) %></td><td class="px-4 py-2"><%= count %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
