<% content_for :page_title, "Products" %>

<div class="flex justify-between items-center mb-4">
  <%= form_tag products_path, method: :get, class: "flex gap-2 items-center" do %>
    <%= text_field_tag :q, params[:q], placeholder: "Search product...", class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= select_tag :category_id, options_from_collection_for_select(ProductCategory.kept, :id, :name, params[:category_id]), { include_blank: "All Categories", class: "rounded border-gray-300 text-sm px-3 py-1.5" } %>
    <%= submit_tag "Filter", class: "bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm hover:bg-gray-200" %>
  <% end %>
  <%= link_to "+ Add Product", new_product_path, class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" if policy(Product).new? %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Unit</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @products.each do |product| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3"><%= link_to product.name, product, class: "text-blue-600 hover:text-blue-800 font-medium" %></td>
          <td class="px-4 py-3 text-sm"><%= product.product_category&.name || "—" %></td>
          <td class="px-4 py-3 text-sm"><%= product.default_unit %></td>
          <td class="px-4 py-3">
            <%= link_to "👁", product, class: "text-gray-600 hover:text-gray-800 mr-2", title: "View" %>
            <%= link_to "✏️", edit_product_path(product), class: "text-gray-600 hover:text-gray-800 mr-2", title: "Edit" if policy(product).edit? %>
            <%= link_to "🗑", product, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800", title: "Delete" if policy(product).destroy? %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @products.empty? %>
    <p class="text-center text-gray-500 py-8">No products found.</p>
  <% end %>
</div>
