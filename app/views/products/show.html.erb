<% content_for :page_title, @product.name %>
<div class="flex gap-2 mb-4">
  <%= link_to "← Back", products_path, class: "text-blue-600 hover:text-blue-800" %>
  <%= link_to "✏️ Edit", edit_product_path(@product), class: "text-blue-600 hover:text-blue-800" if policy(@product).edit? %>
</div>
<div class="bg-white rounded-lg shadow p-6 max-w-lg">
  <dl class="space-y-3">
    <div class="flex justify-between"><dt class="text-gray-500">Name:</dt><dd class="font-medium"><%= @product.name %></dd></div>
    <div class="flex justify-between"><dt class="text-gray-500">Category:</dt><dd><%= @product.product_category&.name || "—" %></dd></div>
    <div class="flex justify-between"><dt class="text-gray-500">Unit:</dt><dd><%= @product.default_unit %></dd></div>
    <div class="flex justify-between"><dt class="text-gray-500">Description:</dt><dd><%= @product.description.presence || "—" %></dd></div>
  </dl>
</div>
