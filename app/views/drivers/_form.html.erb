<%= render "shared/form_errors", object: driver %>

<%= form_with model: driver, class: "space-y-6" do |f| %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <h4 class="text-sm font-semibold text-gray-900 mb-4">👨‍✈️ Driver Details</h4>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="space-y-1">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, required: true, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :phone, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :phone, required: true, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :alternative_phone, "Alt Phone", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :alternative_phone, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :license_number, "License Number", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :license_number, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :status, [["Available", "available"], ["Driving", "driving"], ["Leave", "leave"], ["Inactive", "inactive"]], {}, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>
      <div class="space-y-1">
        <%= f.label :address, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :address, rows: 2, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "bg-blue-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors" %>
    <%= link_to "Cancel", drivers_path, class: "bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
