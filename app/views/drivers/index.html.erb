<% content_for :page_title, "Drivers" %>

<div class="flex justify-between items-center mb-4">
  <%= form_tag drivers_path, method: :get, class: "flex gap-2 items-center" do %>
    <%= text_field_tag :q, params[:q], placeholder: "Search driver...", class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= select_tag :status, options_for_select([["All Status", ""], "Available", "Driving", "Leave", "Inactive"], params[:status]), class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= submit_tag "Filter", class: "bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm hover:bg-gray-200" %>
  <% end %>
  <%= link_to "+ Add Driver", new_driver_path, class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" if policy(Driver).new? %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Phone</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Current Truck</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @drivers.each do |driver| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3"><%= link_to driver.name, driver, class: "text-blue-600 hover:text-blue-800 font-medium" %></td>
          <td class="px-4 py-3 text-sm"><%= driver.phone %></td>
          <td class="px-4 py-3"><%= status_badge(driver.status) %></td>
          <td class="px-4 py-3"><%= driver.current_truck&.truck_number || "—" %></td>
          <td class="px-4 py-3">
            <%= link_to "👁", driver, class: "text-gray-600 hover:text-gray-800 mr-2", title: "View" %>
            <%= link_to "✏️", edit_driver_path(driver), class: "text-gray-600 hover:text-gray-800 mr-2", title: "Edit" if policy(driver).edit? %>
            <%= link_to "🗑", driver, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800", title: "Delete" if policy(driver).destroy? %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @drivers.empty? %>
    <p class="text-center text-gray-500 py-8">No drivers found.</p>
  <% end %>
</div>
