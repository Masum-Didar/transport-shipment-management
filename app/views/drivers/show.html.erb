<% content_for :page_title, "Driver: #{@driver.name}" %>

<div class="flex gap-2 mb-4">
  <%= link_to "← Back", drivers_path, class: "text-blue-600 hover:text-blue-800" %>
  <%= link_to "✏️ Edit", edit_driver_path(@driver), class: "text-blue-600 hover:text-blue-800" if policy(@driver).edit? %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="font-semibold text-gray-700 mb-4">Driver Details</h3>
    <dl class="space-y-3">
      <div class="flex justify-between"><dt class="text-gray-500">Name:</dt><dd class="font-medium"><%= @driver.name %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Phone:</dt><dd><%= @driver.phone %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Alt Phone:</dt><dd><%= @driver.alternative_phone || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">License:</dt><dd><%= @driver.license_number || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Status:</dt><dd><%= status_badge(@driver.status) %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Address:</dt><dd><%= @driver.address.presence || "—" %></dd></div>
    </dl>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="font-semibold text-gray-700 mb-4">🚛 Current Truck</h3>
    <% if @current_truck %>
      <p><%= link_to @current_truck.truck_number, @current_truck, class: "text-blue-600 hover:text-blue-800" %></p>
    <% else %>
      <p class="text-gray-500">Not assigned to any truck</p>
    <% end %>

    <% if policy(DriverAssignment).create? %>
      <%= form_with model: DriverAssignment.new, local: true, class: "mt-4 p-3 bg-gray-50 rounded" do |f| %>
        <h4 class="text-sm font-medium mb-2">Assign to Truck</h4>
        <%= f.hidden_field :driver_id, value: @driver.id %>
        <%= f.collection_select :truck_id, Truck.available, :id, :display_name, { prompt: "Select Truck" }, class: "block w-full rounded border-gray-300 text-sm mb-2" %>
        <%= f.submit "Assign", class: "bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700" %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-lg shadow p-6 mt-6">
  <h3 class="font-semibold text-gray-700 mb-4">📜 Assignment History</h3>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Truck</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Assigned By</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">From</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">To</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @assignments.each do |a| %>
          <tr>
            <td class="px-4 py-2"><%= link_to a.truck.truck_number, a.truck, class: "text-blue-600" %></td>
            <td class="px-4 py-2"><%= a.assigned_by.name %></td>
            <td class="px-4 py-2 text-sm"><%= l(a.assigned_at, format: :short) %></td>
            <td class="px-4 py-2 text-sm"><%= a.released_at ? l(a.released_at, format: :short) : "🟢 Current" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
