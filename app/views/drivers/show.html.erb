<% content_for :page_title, @driver.name %>

<div class="space-y-4">
  <div class="flex items-center gap-3">
    <%= link_to drivers_path, class: "p-2 hover:bg-gray-100 rounded-lg text-gray-500 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    <% end %>
    <h1 class="text-lg font-semibold text-gray-900"><%= @driver.name %></h1>
    <%= link_to edit_driver_path(@driver), class: "ml-auto flex items-center gap-1.5 px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors" do %>
      <%= edit_icon %> Edit
    <% end if policy(@driver).edit? %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 text-center">
      <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center text-2xl font-bold text-blue-700 mx-auto mb-3">
        <%= @driver.name.split.map { |n| n[0] }.join[0..1].upcase %>
      </div>
      <div class="font-semibold text-gray-900 text-base"><%= @driver.name %></div>
      <div class="mt-2"><%= status_badge(@driver.status) %></div>
      <div class="mt-4 space-y-2 text-sm text-left">
        <% details = [
          { label: "Phone", value: @driver.phone },
          { label: "Alt Phone", value: @driver.alternative_phone.presence || "—" },
          { label: "License", value: @driver.license_number.presence || "—" },
          { label: "Address", value: @driver.address.presence || "—" },
          { label: "Truck", value: @current_truck&.truck_number || "Unassigned" },
        ] %>
        <% details.each do |r| %>
          <div class="flex justify-between py-1.5 border-b border-gray-50 last:border-0">
            <span class="text-gray-500 text-xs"><%= r[:label] %></span>
            <span class="font-mono text-xs font-medium text-gray-800"><%= r[:value] %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-2 space-y-4">
    </div>
  </div>
</div>
