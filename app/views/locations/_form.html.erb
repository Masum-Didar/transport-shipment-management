<%= render "shared/form_errors", object: location %>
<%= form_with model: location, class: "space-y-6" do |f| %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <h4 class="text-sm font-semibold text-gray-900 mb-4">📍 Location Details</h4>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="space-y-1">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, required: true, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :location_type, "Type", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :location_type, [["Port", "port"], ["ICD", "icd"], ["Warehouse", "warehouse"], ["Factory", "factory"], ["Border", "border"], ["Other", "other"]], {}, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>
      <div class="space-y-1">
        <%= f.label :city, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :city, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :division, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :division, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :country, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :country, value: location.country || "Bangladesh", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
    </div>
    <div class="mt-4 space-y-1">
      <%= f.label :address, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :address, rows: 2, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
    </div>
  </div>
  <div class="flex gap-2">
    <%= f.submit class: "bg-blue-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors" %>
    <%= link_to "Cancel", locations_path, class: "bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
