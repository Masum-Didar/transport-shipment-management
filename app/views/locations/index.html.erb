<% content_for :page_title, "Locations" %>

<div class="flex justify-between items-center mb-4">
  <%= form_tag locations_path, method: :get, class: "flex gap-2" do %>
    <%= select_tag :type, options_for_select([["All Types", ""], "Port", "ICD", "Warehouse", "Factory", "Border", "Other"], params[:type]), class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
    <%= submit_tag "Filter", class: "bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm hover:bg-gray-200" %>
  <% end %>
  <%= link_to "+ Add Location", new_location_path, class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" if policy(Location).new? %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">City</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Division</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @locations.each do |loc| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium"><%= loc.name %></td>
          <td class="px-4 py-3"><%= status_badge(loc.location_type) %></td>
          <td class="px-4 py-3 text-sm"><%= loc.city || "—" %></td>
          <td class="px-4 py-3 text-sm"><%= loc.division || "—" %></td>
          <td class="px-4 py-3">
            <%= link_to "✏️", edit_location_path(loc), class: "text-gray-600 hover:text-gray-800 mr-2", title: "Edit" if policy(loc).edit? %>
            <%= link_to "🗑", loc, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800", title: "Delete" if policy(loc).destroy? %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @locations.empty? %>
    <p class="text-center text-gray-500 py-8">No locations found.</p>
  <% end %>
</div>
