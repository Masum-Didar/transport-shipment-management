<% content_for :page_title, "Trucks" %>

<div class="flex justify-between items-center mb-4">
  <div>
    <%= form_tag trucks_path, method: :get, class: "flex gap-2 items-center" do %>
      <%= text_field_tag :q, params[:q], placeholder: "Search truck...", class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
      <%= select_tag :status, options_for_select([["All Status", ""], "Available", "Assigned", "Loading", "On Route", "Maintenance", "Inactive"], params[:status]), class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
      <%= select_tag :type, options_for_select([["All Types", ""], ["Company", "company"], ["Outside", "outside"]], params[:type]), class: "rounded border-gray-300 text-sm px-3 py-1.5" %>
      <%= submit_tag "Filter", class: "bg-gray-100 text-gray-700 px-3 py-1.5 rounded text-sm hover:bg-gray-200" %>
    <% end %>
  </div>
  <%= link_to "+ Add Truck", new_truck_path, class: "bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700" if policy(Truck).new? %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Number</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Driver</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Location</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @trucks.each do |truck| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3"><%= link_to truck.truck_number, truck, class: "text-blue-600 hover:text-blue-800 font-medium" %></td>
          <td class="px-4 py-3"><%= status_badge(truck.truck_type) %></td>
          <td class="px-4 py-3"><%= status_badge(truck.status) %></td>
          <td class="px-4 py-3"><%= truck.current_driver&.name || "—" %></td>
          <td class="px-4 py-3 text-sm"><%= truck.current_location&.name || "—" %></td>
          <td class="px-4 py-3">
            <%= link_to "👁", truck, class: "text-gray-600 hover:text-gray-800 mr-2", title: "View" %>
            <%= link_to "✏️", edit_truck_path(truck), class: "text-gray-600 hover:text-gray-800 mr-2", title: "Edit" if policy(truck).edit? %>
            <%= link_to "🗑", truck, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800", title: "Delete" if policy(truck).destroy? %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @trucks.empty? %>
    <p class="text-center text-gray-500 py-8">No trucks found.</p>
  <% end %>
</div>
