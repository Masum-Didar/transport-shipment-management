<% content_for :page_title, "Truck ##{@truck.truck_number}" %>

<div class="flex gap-2 mb-4">
  <%= link_to "← Back", trucks_path, class: "text-blue-600 hover:text-blue-800" %>
  <%= link_to "✏️ Edit", edit_truck_path(@truck), class: "text-blue-600 hover:text-blue-800" if policy(@truck).edit? %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="font-semibold text-gray-700 mb-4">Truck Details</h3>
    <dl class="space-y-3">
      <div class="flex justify-between"><dt class="text-gray-500">Number:</dt><dd class="font-medium"><%= @truck.truck_number %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Type:</dt><dd><%= status_badge(@truck.truck_type) %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Status:</dt><dd><%= status_badge(@truck.status) %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Brand:</dt><dd><%= @truck.brand || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Model:</dt><dd><%= @truck.vehicle_model || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Year:</dt><dd><%= @truck.year || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Capacity:</dt><dd><%= number_with_delimiter(@truck.capacity_kg) %> kg</dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Location:</dt><dd><%= @truck.current_location&.name || "—" %></dd></div>
    </dl>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="font-semibold text-gray-700 mb-4">👨‍✈️ Current Driver</h3>
    <% if @truck.current_driver %>
      <p><%= link_to @truck.current_driver.name, @truck.current_driver, class: "text-blue-600 hover:text-blue-800" %></p>
    <% else %>
      <p class="text-gray-500">No driver assigned</p>
    <% end %>

    <h3 class="font-semibold text-gray-700 mt-6 mb-4">📋 Current Shipment</h3>
    <% if @current_shipment %>
      <p><%= link_to @current_shipment.shipment_number, @current_shipment, class: "text-blue-600 hover:text-blue-800" %></p>
      <p class="text-sm text-gray-500"><%= @current_shipment.source_location&.name %> → <%= @current_shipment.destination_location&.name %></p>
    <% else %>
      <p class="text-gray-500">No active shipment</p>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-lg shadow p-6 mt-6">
  <h3 class="font-semibold text-gray-700 mb-4">📜 Driver Assignment History</h3>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Driver</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Assigned By</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Assigned At</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Released At</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @driver_assignments.each do |da| %>
          <tr>
            <td class="px-4 py-2"><%= link_to da.driver.name, da.driver, class: "text-blue-600" %></td>
            <td class="px-4 py-2"><%= da.assigned_by.name %></td>
            <td class="px-4 py-2 text-sm"><%= l(da.assigned_at, format: :short) %></td>
            <td class="px-4 py-2 text-sm"><%= da.released_at ? l(da.released_at, format: :short) : "🟢 Current" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
