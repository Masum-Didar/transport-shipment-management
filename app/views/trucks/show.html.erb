<% content_for :page_title, @truck.truck_number %>

<div class="space-y-4">
  <div class="flex items-center gap-3">
    <%= link_to trucks_path, class: "p-2 hover:bg-gray-100 rounded-lg text-gray-500 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    <% end %>
    <div>
      <h1 class="text-lg font-bold text-gray-900 font-mono"><%= @truck.truck_number %></h1>
      <p class="text-xs text-gray-500"><%= @truck.truck_type.titleize %> Truck · <%= number_with_delimiter(@truck.capacity_kg) %> kg Capacity</p>
    </div>
    <%= link_to edit_truck_path(@truck), class: "ml-auto flex items-center gap-1.5 px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors" do %>
      <%= edit_icon %> Edit
    <% end if policy(@truck).edit? %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-1 space-y-4">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <div class="text-center mb-5">
          <div class="text-5xl mb-3">🚛</div>
          <div class="font-mono text-xl font-bold text-gray-900"><%= @truck.truck_number %></div>
          <div class="mt-2"><%= status_badge(@truck.status) %></div>
        </div>
        <div class="space-y-3 text-sm">
          <% details = [
            { label: "Type", value: @truck.truck_type.titleize },
            { label: "Capacity", value: "#{number_with_delimiter(@truck.capacity_kg)} kg" },
            { label: "Brand", value: @truck.brand.presence || "—" },
            { label: "Model", value: @truck.vehicle_model.presence || "—" },
            { label: "Year", value: @truck.year.presence || "—" },
            { label: "Location", value: @truck.current_location&.name || "—" },
          ] %>
          <% details.each do |r| %>
            <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
              <span class="text-gray-500 text-xs"><%= r[:label] %></span>
              <span class="font-medium text-gray-800"><%= r[:value] %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-2 space-y-4">
      <% if @current_shipment %>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
          <h2 class="text-sm font-semibold text-gray-900 mb-3">Current Shipment</h2>
          <%= link_to shipment_path(@current_shipment), class: "flex items-center justify-between p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors" do %>
            <div>
              <div class="font-mono text-sm font-bold text-blue-700"><%= @current_shipment.shipment_number %></div>
              <div class="text-xs text-gray-500 mt-0.5"><%= @current_shipment.source_location&.name %> → <%= @current_shipment.destination_location&.name %> · <%= @current_shipment.shipment_type.titleize %></div>
            </div>
            <%= status_badge(@current_shipment.status) %>
          <% end %>
        </div>
      <% end %>


    </div>
  </div>
</div>
