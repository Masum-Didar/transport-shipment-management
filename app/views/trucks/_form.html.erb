<%= render "shared/form_errors", object: truck %>

<%= form_with model: truck, class: "space-y-6" do |f| %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <h4 class="text-sm font-semibold text-gray-900 mb-4">🚛 Truck Details</h4>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="space-y-1">
        <%= f.label :truck_number, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :truck_number, required: true, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :truck_type, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :truck_type, [["Company", "company"], ["Outside", "outside"]], { prompt: "Select Type" }, required: true, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>
      <div class="space-y-1">
        <%= f.label :brand, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :brand, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :vehicle_model, "Model", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :vehicle_model, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :year, class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :year, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :capacity_kg, "Capacity (kg)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :capacity_kg, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
      </div>
      <div class="space-y-1">
        <%= f.label :current_location_id, "Location", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :current_location_id, Location.kept, :id, :name, { prompt: "Select Location" }, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>
      <div class="space-y-1">
        <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :status, [["Available", "available"], ["Assigned", "assigned"], ["Loading", "loading"], ["On Route", "on_route"], ["Maintenance", "maintenance"], ["Inactive", "inactive"]], {}, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "bg-blue-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors" %>
    <%= link_to "Cancel", trucks_path, class: "bg-white border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
