<%= render "shared/form_errors", object: truck %>

<%= form_with model: truck, class: "space-y-4" do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :truck_number, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :truck_number, required: true, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :truck_type, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :truck_type, [["Company", "company"], ["Outside", "outside"]], {}, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :brand, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :brand, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :vehicle_model, "Model", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :vehicle_model, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :year, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :year, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :capacity_kg, "Capacity (kg)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :capacity_kg, step: 0.01, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :status, [["Available", "available"], ["Assigned", "assigned"], ["Loading", "loading"], ["On Route", "on_route"], ["Maintenance", "maintenance"], ["Inactive", "inactive"]], {}, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.label :current_location_id, "Current Location", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :current_location_id, Location.kept, :id, :name, { include_blank: "Select Location" }, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
  </div>
  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full rounded border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>
  <div class="flex gap-2">
    <%= f.submit class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    <%= link_to "Cancel", trucks_path, class: "bg-gray-100 text-gray-700 px-4 py-2 rounded hover:bg-gray-200" %>
  </div>
<% end %>
