<% content_for :page_title, "Audit Log" %>

<div class="space-y-4">
  <h1 class="text-xl font-semibold text-gray-900">Audit Log</h1>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Time</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Record</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if @logs.empty? %>
            <tr>
              <td colspan="4">
                <%= render EmptyStateComponent.new(icon: "📝", title: "No audit logs yet", description: "Actions will be recorded here as you use the system") %>
              </td>
            </tr>
          <% else %>
            <% @logs.each do |log| %>
              <tr class="hover:bg-blue-50/40 transition-colors duration-100">
                <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap"><%= l(log.created_at, format: :short) %></td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= log.user&.name || "System" %></td>
                <td class="px-4 py-3"><%= status_badge(log.action) %></td>
                <td class="px-4 py-3 text-sm text-gray-600">#<%= log.auditable_id %> (<%= log.auditable_type.underscore.humanize %>)</td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
